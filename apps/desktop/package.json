{
  "name": "@codeforge/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:next": "next dev",
    "dev:electron": "electron .",
    "build:next": "next build",
    "build": "next build && electron-builder",
    "start": "next start"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "monaco-editor": "^0.55.1",
    "next": "^14.2.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codeforge.ai",
    "productName": "CodeForge AI",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}